# MawiTek Trading Bot — environment template.
# Copy to `.env` and fill in your own values. `.env` is gitignored — NEVER commit
# real secrets. Everything except the Tradier keys is optional; unset features
# simply stay off.

# ── Broker: Tradier (required) ─────────────────────────────────────────────
TRADIER_API_KEY=your-tradier-access-token
TRADIER_ACCOUNT_ID=your-tradier-account-id
TRADIER_SANDBOX=true              # true = sandbox/paper, false = LIVE money

# ── Contact (optional) ─────────────────────────────────────────────────────
# Sent as the User-Agent contact on SEC/news requests (SEC asks for a real one).
CONTACT_EMAIL=contact@example.com

# ── Alerts: Telegram (optional) ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Alerts: Discord webhook (optional) ─────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Alerts: email / SMS via SMTP (optional) ────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_SMS_TO=                     # carrier gateway, e.g. 5551234567@vtext.com
SMS_ALL_EVENTS=false              # true = text on every event, not just urgent

# ── Dashboard auth (optional; set BOTH to require a login) ─────────────────
# Required before exposing the dashboard beyond localhost (e.g. over Tailscale).
DASH_AUTH_USER=
DASH_AUTH_PASS=

# ── Data sources (optional) ────────────────────────────────────────────────
UNUSUAL_WHALES_API_KEY=           # options flow; feature off if unset
# News + social source toggles — leave unset to use the built-in defaults.
NEWS_SEC=
NEWS_GOOGLE=
NEWS_YFINANCE=
NEWS_TRADIER=
SOCIAL_REDDIT=
SOCIAL_STOCKTWITS=
